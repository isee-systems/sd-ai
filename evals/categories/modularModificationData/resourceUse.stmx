	<model name="Population">
		<variables>
			<stock name="Population" access="output" isee:autocreated="true">
				<eqn>100</eqn>
				<inflow>births</inflow>
				<outflow>deaths</outflow>
				<non_negative/>
				<units>critters</units>
			</stock>
			<flow name="births">
				<eqn>Population*birth_rate*effect_of_resource_use_on_births</eqn>
				<non_negative/>
				<units>critters/years</units>
			</flow>
			<flow name="deaths">
				<eqn>Population/lifespan*effect_of_resource_use_on_deaths</eqn>
				<non_negative/>
				<units>critters/years</units>
			</flow>
			<aux name="birth rate">
				<eqn>.02</eqn>
				<units>1/year</units>
			</aux>
			<aux name="lifespan">
				<eqn>80</eqn>
				<units>years</units>
			</aux>
			<aux name="resource use per\nperson" access="input">
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>Resource/Person/Year</units>
			</aux>
			<aux name="effect of\nresource use on births">
				<eqn>resource_use_per_person/INIT(resource_use_per_person)</eqn>
				<gf>
					<xscale min="0" max="1"/>
					<yscale min="0" max="1"/>
					<ypts>0,0.3991,0.6399,0.7852,0.8729,0.9259,0.9578,0.9771,0.9887,0.9958,1</ypts>
				</gf>
				<units>Dimensionless</units>
			</aux>
			<aux name="effect of resource use on deaths">
				<eqn>resource_use_per_person</eqn>
				<gf>
					<xscale min="0" max="1"/>
					<yscale min="1" max="2"/>
					<ypts>2,1.595,1.353,1.208,1.122,1.07,1.04,1.021,1.01,1.004,1</ypts>
				</gf>
			</aux>
		</variables>
