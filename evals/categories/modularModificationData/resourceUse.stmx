	<model name="Resources">
		<variables>
			<stock name="Population" access="input">
				<eqn>100</eqn>
				<non_negative/>
				<units>critters</units>
			</stock>
			<stock name="Natural Resources">
				<eqn>100000</eqn>
				<outflow>using_resources</outflow>
				<non_negative/>
				<units>resource</units>
			</stock>
			<flow name="using resources">
				<eqn>resource_use_per_person*Population</eqn>
				<non_negative/>
				<units>resource/years</units>
			</flow>
			<aux name="resource use per\nperson" access="output" isee:autocreated="true">
