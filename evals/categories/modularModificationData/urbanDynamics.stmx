							<isee:series_style color="#F586FF" thickness="1" pen_style="dotted"/>
							<isee:series_style color="black" thickness="1" pen_style="dashed"/>
							<isee:series_style color="#C8C8C8" thickness="1"/>
						</isee:series_styles>
					</graph>
					<table color="black" background="#E0E0E0" text_align="right" font_size="12pt" orientation="vertical" wrap_text="false" isee:auto_fit="true" isee:use_alternate_row_colors="false" isee:unlimited_table_length="false" blank_column_width="80" column_width="160" interval="1" report_balances="beginning" report_flows="instantaneous" header_font_style="normal" header_font_weight="normal" header_text_decoration="none" header_text_align="center" header_vertical_text_align="center" header_font_color="black" header_font_family="Arial" header_font_size="12pt" header_text_padding="2" header_text_border_color="black" header_text_border_width="thin" header_text_border_style="none"/>
				</style>
				<flow x="425.5" y="480" name="business starts">
					<pts>
						<pt x="383.5" y="480"/>
						<pt x="467.5" y="480"/>
					</pts>
				</flow>
				<flow x="548.5" y="480" name="business closures">
					<pts>
						<pt x="512.5" y="480"/>
						<pt x="608.5" y="480"/>
					</pts>
				</flow>
				<aux x="474" y="593" name="base start fraction"/>
				<aux x="536" y="355" name="closure fraction"/>
				<aux x="251" y="413" name="target labor per business"/>
				<aux x="401" y="349" name="relative labor availability"/>
				<aux x="312" y="219" name="start multiplier"/>
				<aux x="669" y="714" name="jobs per structure"/>
				<aux x="574" y="603" name="total jobs"/>
				<stock x="490" y="480" name="Business Structures"/>
				<stock font_style="italic" font_weight="bold" x="514" y="231" name="Population"/>
				<connector uid="1" polarity="+" isee:polarity_placement="outside" angle="220">
					<isee:documentation>Reasoning:
Business starts are calculated as a fraction of the existing business structures.

Polarity Reasoning: 
Positive polarity because structures and starts move in the same direction.</isee:documentation>
					<isee:reasoning>Business starts are calculated as a fraction of the existing business structures.</isee:reasoning>
					<isee:polarity_reasoning>Positive polarity because structures and starts move in the same direction.</isee:polarity_reasoning>
					<from>Business_Structures</from>
					<to>business_starts</to>
				</connector>
				<connector uid="2" polarity="+" isee:polarity_placement="outside" angle="40">
					<isee:documentation>Reasoning:
Business closures are calculated as a fraction of the existing business structures.

Polarity Reasoning: 
Positive polarity because structures and closures move in the same direction.</isee:documentation>
					<isee:reasoning>Business closures are calculated as a fraction of the existing business structures.</isee:reasoning>
					<isee:polarity_reasoning>Positive polarity because structures and closures move in the same direction.</isee:polarity_reasoning>
					<from>Business_Structures</from>
					<to>business_closures</to>
				</connector>
				<connector uid="3" polarity="+" isee:polarity_placement="outside" angle="113.229">
					<isee:documentation>Reasoning:
A higher base start fraction increases the business start rate.

Polarity Reasoning: 
Positive polarity because fraction and starts move in the same direction.</isee:documentation>
					<isee:reasoning>A higher base start fraction increases the business start rate.</isee:reasoning>
					<isee:polarity_reasoning>Positive polarity because fraction and starts move in the same direction.</isee:polarity_reasoning>
					<from>base_start_fraction</from>
					<to>business_starts</to>
				</connector>
				<connector uid="4" polarity="+" isee:polarity_placement="outside" angle="275.711">
					<isee:documentation>Reasoning:
A higher closure fraction increases the business closure rate.

Polarity Reasoning: 
Positive polarity because fraction and closures move in the same direction.</isee:documentation>
					<isee:reasoning>A higher closure fraction increases the business closure rate.</isee:reasoning>
					<isee:polarity_reasoning>Positive polarity because fraction and closures move in the same direction.</isee:polarity_reasoning>
					<from>closure_fraction</from>
					<to>business_closures</to>
				</connector>
				<connector uid="5" polarity="+" isee:polarity_placement="outside" angle="293.503">
					<isee:documentation>Reasoning:
A higher start multiplier increases the business start rate.

Polarity Reasoning: 
Positive polarity because multiplier and starts move in the same direction.</isee:documentation>
					<isee:reasoning>A higher start multiplier increases the business start rate.</isee:reasoning>
					<isee:polarity_reasoning>Positive polarity because multiplier and starts move in the same direction.</isee:polarity_reasoning>
					<from>start_multiplier</from>
					<to>business_starts</to>
				</connector>
				<connector uid="6" polarity="+" isee:polarity_placement="outside" angle="104.644">
					<isee:documentation>Reasoning:
Higher labor availability encourages more business starts.

Polarity Reasoning: 
Positive polarity because availability and multiplier move in the same direction.</isee:documentation>
					<isee:reasoning>Higher labor availability encourages more business starts.</isee:reasoning>
					<isee:polarity_reasoning>Positive polarity because availability and multiplier move in the same direction.</isee:polarity_reasoning>
					<from>relative_labor_availability</from>
					<to>start_multiplier</to>
				</connector>
				<connector uid="7" polarity="+" isee:polarity_placement="outside" angle="226.24">
					<isee:documentation>Reasoning:
A larger population increases the availability of labor for businesses.

Polarity Reasoning: 
Positive polarity because population and availability move in the same direction.</isee:documentation>
					<isee:reasoning>A larger population increases the availability of labor for businesses.</isee:reasoning>
					<isee:polarity_reasoning>Positive polarity because population and availability move in the same direction.</isee:polarity_reasoning>
					<from>Population</from>
					<to>relative_labor_availability</to>
				</connector>
				<connector uid="8" polarity="-" isee:polarity_placement="outside" angle="104.192">
					<isee:documentation>Reasoning:
More business structures decrease the relative availability of labor per business.

Polarity Reasoning: 
Negative polarity because structures and availability move in opposite directions.</isee:documentation>
					<isee:reasoning>More business structures decrease the relative availability of labor per business.</isee:reasoning>
					<isee:polarity_reasoning>Negative polarity because structures and availability move in opposite directions.</isee:polarity_reasoning>
					<from>Business_Structures</from>
					<to>relative_labor_availability</to>
				</connector>
				<connector uid="9" polarity="-" isee:polarity_placement="outside" angle="23.1063">
					<isee:documentation>Reasoning:
A higher target for labor per business makes the current availability look lower relatively.

Polarity Reasoning: 
Negative polarity because target and relative availability move in opposite directions.</isee:documentation>
					<isee:reasoning>A higher target for labor per business makes the current availability look lower relatively.</isee:reasoning>
					<isee:polarity_reasoning>Negative polarity because target and relative availability move in opposite directions.</isee:polarity_reasoning>
					<from>target_labor_per_business</from>
					<to>relative_labor_availability</to>
				</connector>
				<connector uid="10" polarity="+" isee:polarity_placement="outside" angle="304.33">
					<isee:documentation>Reasoning:
More business structures provide more total jobs.

Polarity Reasoning: 
Positive polarity because structures and jobs move in the same direction.</isee:documentation>
					<isee:reasoning>More business structures provide more total jobs.</isee:reasoning>
					<isee:polarity_reasoning>Positive polarity because structures and jobs move in the same direction.</isee:polarity_reasoning>
					<from>Business_Structures</from>
					<to>total_jobs</to>
				</connector>
				<connector uid="11" polarity="+" isee:polarity_placement="outside" angle="130.559">
					<isee:documentation>Reasoning:
More jobs per structure increase the total number of jobs.

Polarity Reasoning: 
Positive polarity because jobs per structure and total jobs move in the same direction.</isee:documentation>
					<isee:reasoning>More jobs per structure increase the total number of jobs.</isee:reasoning>
					<isee:polarity_reasoning>Positive polarity because jobs per structure and total jobs move in the same direction.</isee:polarity_reasoning>
					<from>jobs_per_structure</from>
					<to>total_jobs</to>
				</connector>
			</view>
		</views>
	</model>
	<model name="Housing">
		<variables>
			<flow name="construction" ai_state="C">
				<doc>The rate at which new housing units are built.</doc>
				<eqn>Housing_Stock*base_construction_fraction*construction_multiplier</eqn>
				<non_negative/>
				<units>units/years</units>
			</flow>
			<flow name="demolition" ai_state="C">
				<doc>The rate at which housing units are removed from the stock.</doc>
				<eqn>Housing_Stock*demolition_fraction</eqn>
				<non_negative/>
				<units>units/years</units>
			</flow>
			<aux name="base construction fraction" ai_state="C">
				<doc>The normal fraction of housing stock added through construction.</doc>
				<eqn>0.05</eqn>
				<units>1/year</units>
			</aux>
			<aux name="demolition fraction" ai_state="C">
				<doc>The fraction of housing stock demolished annually.</doc>
				<eqn>0.02</eqn>
				<units>1/year</units>
			</aux>
			<aux name="target persons per house" ai_state="C">
				<doc>The desired number of people per housing unit.</doc>
				<eqn>2.5</eqn>
				<units>people/unit</units>
			</aux>
			<aux name="relative housing demand" ai_state="C">
				<doc>The ratio of actual people per house to the target people per house.</doc>
				<eqn>(Population/Housing_Stock)//target_persons_per_house</eqn>
				<units>dimensionless</units>
			</aux>
			<aux name="construction multiplier" ai_state="C">
				<doc>A multiplier representing how housing demand influences construction rates.</doc>
				<eqn>relative_housing_demand</eqn>
				<gf>
					<yscale min="0" max="3"/>
					<xpts>0,0.5,1,1.5,2</xpts>
					<ypts>0,0.2,1,2,3</ypts>
				</gf>
				<units>dimensionless</units>
			</aux>
			<stock name="Housing Stock" ai_state="C" access="output" isee:autocreated="true">
				<doc>The total number of housing units available.</doc>
				<eqn>4000</eqn>
				<inflow>construction</inflow>
				<outflow>demolition</outflow>
				<units>units</units>
			</stock>
			<stock name="Population" ai_state="C" access="input">
				<eqn>10000</eqn>
				<units>people</units>
			</stock>
		</variables>
		<views>
