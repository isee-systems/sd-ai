	<model>
		<variables>
			<module name="Population" isee:label="" ai_state="D">
				<connect to="Commerce.Population" from="Population.Population"/>
				<connect2 to="Commerce.Population" from="Population.Population"/>
				<connect to="Housing.Population" from="Population.Population"/>
				<connect2 to="Housing.Population" from="Population.Population"/>
				<connect to="Population.Housing_Stock" from="Housing.Housing_Stock"/>
				<connect2 to="Population.Housing_Stock" from="Housing.Housing_Stock"/>
				<connect to="Population.total_jobs" from="Commerce.total_jobs"/>
				<connect2 to="Population.total_jobs" from="Commerce.total_jobs"/>
			</module>
			<module name="Housing" isee:label="" ai_state="C">
				<connect to="Population.Housing_Stock" from="Housing.Housing_Stock"/>
				<connect2 to="Population.Housing_Stock" from="Housing.Housing_Stock"/>
				<connect to="Housing.Population" from="Population.Population"/>
				<connect2 to="Housing.Population" from="Population.Population"/>
			</module>
			<module name="Commerce" isee:label="" ai_state="C">
				<connect to="Population.total_jobs" from="Commerce.total_jobs"/>
				<connect2 to="Population.total_jobs" from="Commerce.total_jobs"/>
				<connect to="Commerce.Population" from="Population.Population"/>
				<connect2 to="Commerce.Population" from="Population.Population"/>
			</module>
		</variables>
