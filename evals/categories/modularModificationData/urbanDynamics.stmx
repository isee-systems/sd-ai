	</model>
	<model name="Commerce">
		<variables>
			<flow name="business starts" ai_state="C">
				<doc>The rate at which new businesses are established.</doc>
				<eqn>Business_Structures*base_start_fraction*start_multiplier</eqn>
				<non_negative/>
				<units>structures/years</units>
			</flow>
			<flow name="business closures" ai_state="C">
				<doc>The rate at which businesses close.</doc>
				<eqn>Business_Structures*closure_fraction</eqn>
				<non_negative/>
				<units>structures/years</units>
			</flow>
			<aux name="base start fraction" ai_state="C">
				<doc>The normal fraction of business structures added through new starts.</doc>
				<eqn>0.05</eqn>
				<units>1/year</units>
			</aux>
			<aux name="closure fraction" ai_state="C">
				<doc>The fraction of businesses that close annually.</doc>
				<eqn>0.03</eqn>
				<units>1/year</units>
			</aux>
			<aux name="target labor per business" ai_state="C">
				<doc>The desired number of people available per business structure.</doc>
				<eqn>20</eqn>
				<units>people/structure</units>
			</aux>
			<aux name="relative labor availability" ai_state="C">
				<doc>The ratio of actual labor availability to the target labor availability.</doc>
				<eqn>(Population/Business_Structures)//target_labor_per_business</eqn>
				<units>dimensionless</units>
			</aux>
			<aux name="start multiplier" ai_state="C">
				<doc>A multiplier representing how labor availability influences business starts.</doc>
				<eqn>relative_labor_availability</eqn>
				<gf>
					<yscale min="0" max="3"/>
					<xpts>0,0.5,1,1.5,2</xpts>
					<ypts>0,0.2,1,2,3</ypts>
				</gf>
				<units>dimensionless</units>
			</aux>
			<aux name="jobs per structure" ai_state="C">
				<doc>The average number of jobs provided by each business structure.</doc>
				<eqn>20</eqn>
				<units>jobs/structure</units>
			</aux>
			<aux name="total jobs" ai_state="C" access="output" isee:autocreated="true">
				<doc>The total number of jobs available in the urban area.</doc>
				<eqn>Business_Structures*jobs_per_structure</eqn>
				<units>jobs</units>
			</aux>
			<stock name="Business Structures" ai_state="C">
				<doc>The total number of commercial structures or businesses.</doc>
				<eqn>500</eqn>
				<inflow>business_starts</inflow>
				<outflow>business_closures</outflow>
				<units>structures</units>
			</stock>
			<stock name="Population" ai_state="C" access="input">
				<eqn>10000</eqn>
				<units>people</units>
			</stock>
		</variables>
		<views>
			<style color="black" background="white" font_style="normal" font_weight="normal" text_decoration="none" text_align="center" vertical_text_align="center" font_color="black" font_family="Arial" font_size="10pt" padding="2" border_color="black" border_width="thin" border_style="none">
